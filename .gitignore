# ==============================
# Quintessence Git Ignore
# Portfolio-safe public repository
# ==============================

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# FastAPI / backend local runtime
backend/.env

# Keep runtime folders visible, but ignore their contents
backend/data/*
!backend/data/.gitkeep

backend/storage/*
!backend/storage/.gitkeep

backend/backups/*
!backend/backups/.gitkeep

backend/exports/*
!backend/exports/.gitkeep

# Local database files anywhere
*.db
*.sqlite
*.sqlite3

# Node / frontend
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.vite/
node_modules/
dist/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backups and exports
backups/
exports/
*.zip
*.7z
*.rar
*.tar
*.gz

# Environment files
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE/editor
.vscode/
.idea/

# Temporary files
tmp/
temp/
*.tmp
